# ─── Environment Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in the values — never commit .env to git

# Application Base URL
BASE_URL=http://localhost:3000

# PRAGMA Test Tenant Credentials
TEST_USER_EMAIL=testuser@pragma-e2e.com
TEST_USER_PASSWORD=Pragmae2e
TEST_TENANT_NAME=pragma-e2e

# Test Tenant ID for data cleanup after test runs
TEST_TENANT_ID=

# Database connection string (Prisma — for cleanup script)
DATABASE_URL=postgresql://user:password@host:5432/database

# Environment label (local | staging | production)
ENVIRONMENT=local
