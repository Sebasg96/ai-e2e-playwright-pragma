# ─── Environment Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in the values — never commit .env to git

# Application Base URL
BASE_URL=http://localhost:3000

# PRAGMA Test Tenant Credentials
TEST_USER_EMAIL=testuser@pragma-e2e.com
TEST_USER_PASSWORD=your_secure_password_here
TEST_TENANT_NAME=pragma-e2e-test

# Environment label (local | staging | production)
ENVIRONMENT=local
